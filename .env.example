# Public Key ID (frontend). Use rzp_test_… locally; rzp_live_… in production.
VITE_RAZORPAY_KEY_ID=rzp_test_YourKeyIdHere

# Server-only secrets — never use VITE_ prefix
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID=
WORKSHOP_FEE_INR=499

# Public seat counter (hero shows "29 of 40 seats", then decrements on paid regs)
SEATS_TOTAL=40
SEATS_REMAINING_START=29
# Optional: ignore this many existing Razorpay workshop payments when computing remaining
# SEATS_PAID_BASELINE=0

# Admin panel (/admin) — required to view seat reservations
ADMIN_PASSWORD=change-me-strong-password
ADMIN_SECRET=

VITE_META_PIXEL_ID=
